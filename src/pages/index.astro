    const COINS = Object.keys(YIELD_DATA);
    const STRATEGY_LABELS = {
      "not-staking":    "Not staking",
      "native-staking": "Native staking",
      "liquid-staking": "Liquid staking",
      "defi-lp":        "DeFi LP",
    };

    function riskStars(n) {
      return '★'.repeat(n) + '☆'.repeat(5 - n);
    }

    function fmt(n) {
      if (n >= 1000) return '$' + (n / 1000).toFixed(1) + 'k';
      return '$' + n.toFixed(0);
    }

    // =============================================
    //  BUILD COIN ROWS
    // =============================================
    let rowCount = 0;

    function coinOptions(selected = '') {
      return COINS.map(c =>
        `<option value="${c}" ${c === selected ? 'selected' : ''}>${c} — ${YIELD_DATA[c].name}</option>`
      ).join('');
    }

    function strategyOptions(selected = 'not-staking') {
      return Object.entries(STRATEGY_LABELS).map(([v, l]) =>
        `<option value="${v}" ${v === selected ? 'selected' : ''}>${l}</option>`
      ).join('');
    }

    function addRow(coin = '', amount = '', strategy = 'not-staking') {
      if (rowCount >= 15) return;
      const id = ++rowCount;
      const defaultCoin = coin || COINS[(id - 1) % COINS.length];
      const row = document.createElement('div');
      row.className = 'coin-row';
      row.dataset.rowId = id;
      row.innerHTML = `
        <div class="field">
          ${id === 1 ? '<label>Coin</label>' : ''}
          <select class="sel-coin">${coinOptions(defaultCoin)}</select>
        </div>
        <div class="field">
          ${id === 1 ? '<label>Amount</label>' : ''}
          <input type="number" class="inp-amount" min="0" step="any"
                 placeholder="0.00" value="${amount}" />
        </div>
        <div class="field strategy-col">
          ${id === 1 ? '<label>Current Strategy</label>' : ''}
          <select class="sel-strategy">${strategyOptions(strategy)}</select>
        </div>
        <button class="remove-btn" type="button" title="Remove" style="${id === 1 ? 'margin-top:22px' : ''}">&#x2715;</button>
      `;
      row.querySelector('.remove-btn').addEventListener('click', () => {
        row.remove();
        updateAddButton();
      });
      document.getElementById('coin-rows').appendChild(row);
      updateAddButton();
    }

    function updateAddButton() {
      const rows = document.querySelectorAll('.coin-row').length;
      const btn = document.getElementById('btn-add-coin');
      btn.style.display = rows >= 15 ? 'none' : 'flex';
    }

    document.getElementById('btn-add-coin').addEventListener('click', () => addRow());

    // Issue 5: Load from localStorage on page load
    (function initRows() {
      try {
        const saved = JSON.parse(localStorage.getItem('cyg-portfolio') || '[]');
        if (saved.length > 0) {
          saved.forEach(h => addRow(h.coin, h.amount, h.strategy));
        } else {
          addRow();
        }
      } catch (e) {
        addRow();
      }
    })();

    // =============================================
    //  OPTIMIZE
    // =============================================
    document.getElementById('btn-optimize').addEventListener('click', async () => {
      const btn = document.getElementById('btn-optimize');
      const errEl = document.getElementById('error-msg');
      errEl.style.display = 'none';

      // Gather rows
      const rows = [...document.querySelectorAll('.coin-row')];
      const holdings = rows.map(r => ({
        coin:     r.querySelector('.sel-coin').value,
        amount:   parseFloat(r.querySelector('.inp-amount').value) || 0,
        strategy: r.querySelector('.sel-strategy').value,
      })).filter(h => h.amount > 0);

      if (holdings.length === 0) {
        errEl.textContent = 'Please enter at least one holding with an amount greater than 0.';
        errEl.style.display = 'block';
        return;
      }

      // Issue 5: Save to localStorage
      try {
        localStorage.setItem('cyg-portfolio', JSON.stringify(holdings));
      } catch (e) { /* storage unavailable */ }

      btn.disabled = true;
      btn.innerHTML = '<span class="spinner"></span>Fetching live prices…';

      // Fetch prices
      const coinIds = [...new Set(holdings.map(h => YIELD_DATA[h.coin].coingecko))].join(',');
      let prices = {};
      try {
        const res = await fetch(
          `https://api.coingecko.com/api/v3/simple/price?ids=${coinIds}&vs_currencies=usd`,
          { signal: AbortSignal.timeout(8000) }
        );
        if (!res.ok) throw new Error('CoinGecko API error');
        const data = await res.json();
        for (const [coin, info] of Object.entries(YIELD_DATA)) {
          if (data[info.coingecko]) prices[coin] = data[info.coingecko].usd;
        }
      } catch (e) {
        // Fallback prices (rough estimates — shown with disclaimer)
        prices = { BTC:97000, ETH:3400, SOL:185, ADA:0.85, DOT:9.5, BNB:680, AVAX:38, LINK:18, SUI:3.8, RAY:2.8, ATOM:8, MATIC:0.55, NEAR:5, FTM:0.65, APT:7 };
        errEl.textContent = '⚠ Could not fetch live prices — using approximate values. Refresh to retry.';
        errEl.style.display = 'block';
      }

      btn.disabled = false;
      btn.innerHTML = 'Optimize My Yield';

      // Calculate results
      let totalNow = 0, totalOpt = 0;
      const coinResultsEl = document.getElementById('coin-results');
      coinResultsEl.innerHTML = '';

      for (const h of holdings) {
        const yieldInfo   = YIELD_DATA[h.coin];
        const price       = prices[h.coin] || 0;
        const usdValue    = h.amount * price;
        const curStrat    = yieldInfo.strategies[h.strategy];
        const bestStratKey= yieldInfo.best;
        const bestStrat   = yieldInfo.strategies[bestStratKey];
        const curAnnual   = usdValue * (curStrat.apy  / 100);
        const bestAnnual  = usdValue * (bestStrat.apy / 100);
        const extra       = bestAnnual - curAnnual;

        totalNow += curAnnual;
        totalOpt += bestAnnual;

        const isAlreadyBest = h.strategy === bestStratKey;
        const badgeClass    = isAlreadyBest ? 'optimized' : 'upgrade';
        const badgeText     = isAlreadyBest ? 'Already optimized' : 'Upgrade available';

        // Issue 6: Build affiliate buttons
        const affiliateHTML = (yieldInfo.affiliates || []).map(a =>
          `<a class="btn-affiliate" href="${a.url}" target="_blank" rel="noopener sponsored">Get started with ${a.name} →</a>`
        ).join('');

        const card = document.createElement('div');
        card.className = 'coin-result';
        card.innerHTML = `
          <div class="cr-header">
            <div class="cr-coin-name">${h.coin} — ${yieldInfo.name}</div>
            <div class="cr-amount">${h.amount.toLocaleString(undefined, {maximumFractionDigits: 6})} ${h.coin} ≈ ${fmt(usdValue)}</div>
            <div class="cr-badge ${badgeClass}">${badgeText}</div>
          </div>
          <div class="cr-grid">
            <div class="cr-box">
              <div class="cr-box-label">Current</div>
              <div class="cr-strategy">${curStrat.label}</div>
              <div class="cr-apy current">${curStrat.apyDisplay} APY</div>
              <div class="cr-annual">${fmt(curAnnual)}/year</div>
            </div>
            <div class="cr-box">
              <div class="cr-box-label">Recommended</div>
              <div class="cr-strategy">${bestStrat.label}</div>
              <div class="cr-apy optimized">${bestStrat.apyDisplay} APY <span class="apy-updated">Last updated: April 2026</span></div>
              <div class="cr-annual">${fmt(bestAnnual)}/year</div>
            </div>
          </div>
          ${extra > 0 ? `
          <div class="cr-extra">
            <div class="cr-extra-left">Extra yield per year</div>
            <div class="cr-extra-right">+${fmt(extra)}/yr</div>
          </div>` : ''}
          <div class="cr-footer">
            <div class="cr-risk">Risk: <span>${riskStars(bestStrat.risk)}</span> (${bestStrat.risk}/5)</div>
            <div class="cr-note">${yieldInfo.note}</div>
          </div>
          <div class="cr-disclaimer">Yields are approximate and fluctuate daily. Not financial advice — always verify current rates before investing.</div>
          ${affiliateHTML ? `<div class="cr-affiliate">${affiliateHTML}</div>` : ''}
        `;
        coinResultsEl.appendChild(card);
      }

      // Update totals
      const diff = totalOpt - totalNow;
      document.getElementById('t-now').textContent  = fmt(totalNow) + '/yr';
      document.getElementById('t-opt').textContent  = fmt(totalOpt) + '/yr';
      document.getElementById('t-diff').textContent = '+' + fmt(diff) + '/yr';

      // Show sections
      document.getElementById('results').style.display = 'block';
      document.getElementById('email-section').style.display = 'block';

      // Octalysis #2: Optimization score
      const optPct = totalNow > 0 ? Math.round(((totalOpt - totalNow) / totalNow) * 100) : 0;
      const scoreEl = document.getElementById('opt-score');
      scoreEl.textContent = `+${optPct}% yield improvement possible`;
      document.getElementById('progress-section').style.display = 'block';

      document.getElementById('results').scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
